{
  "version": "2026-03-16",
  "principle": "通知は甲原さんの次の行動を変えるものだけ送る。",
  "decision_checks": {
    "owner_action_required": "甲原さんの確認・判断・承認・返信・認証が必要",
    "time_sensitive": "今見ないと価値が大きく落ちる",
    "external_impact": "顧客・社外・対外送信・重要データ更新に影響する",
    "manual_recovery_required": "秘書が自動復旧できず人の介入が必要",
    "review_today_value": "即時性はないが今日の判断材料として価値がある"
  },
  "delivery_classes": {
    "immediate": {
      "notify_when_any": [
        "owner_action_required",
        "time_sensitive",
        "external_impact",
        "manual_recovery_required"
      ],
      "requires_next_action": true,
      "default_cooldown_minutes": 60
    },
    "digest": {
      "notify_when_any": [
        "review_today_value"
      ],
      "batched": true
    },
    "silent": {
      "description": "通知せず、ログまたは state だけ更新する"
    }
  },
  "recovery_rules": {
    "notify_only_if_prior_human_action_requested": true,
    "suppress_self_healed_success": true
  },
  "message_requirements": {
    "order": [
      "conclusion",
      "impact",
      "next_action"
    ],
    "include_open_location_for_ui_checks": true,
    "single_action_per_message": true
  },
  "event_defaults": {
    "approval_request": "immediate",
    "reply_confirmation": "immediate",
    "auth_expired": "immediate",
    "manual_2fa_required": "immediate",
    "sync_failure": "immediate",
    "render_down": "immediate",
    "api_credit_shortage": "immediate",
    "deadline_failure": "immediate",
    "deadline_reminder": "immediate",
    "kpi_anomaly": "immediate",
    "daily_briefing": "digest",
    "calendar_digest": "digest",
    "mail_waiting_digest": "digest",
    "group_digest": "digest",
    "weekly_insight": "digest",
    "content_suggestion": "digest",
    "followup_suggestion": "digest",
    "meeting_report_ready": "digest",
    "internal_success": "silent",
    "cache_refresh_success": "silent",
    "sync_success": "silent",
    "deploy_success": "silent",
    "auto_restart_success": "silent",
    "keepalive_success": "silent",
    "self_healed_success": "silent",
    "no_op": "silent"
  }
}
