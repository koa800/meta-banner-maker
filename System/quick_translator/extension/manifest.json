{
  "manifest_version": 3,
  "name": "Quick Translator",
  "version": "1.0.0",
  "description": "テキスト選択で自動翻訳ポップアップ",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Quick Translator ON/OFF"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
