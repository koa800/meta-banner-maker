#!/bin/bash
# ai - Claude Code / Codex CLI シームレス切り替えラッパー
#
# 設計思想:
#   モデルは「もう一人の担当者」。引き継ぎは人間同士と同じレベルで行う。
#   伝達率を1%も落とさないために、引き継ぎを構造化・自動化する。
#
# 使い方:
#   ai "広告CRの競合分析して"       → 自動判別でCodex
#   ai "このバグ直して"             → 自動判別でCodex
#   ai claude "Looker Studioを確認して" → 明示的にClaude Code
#   ai switch                      → ツール間切り替え（自動引き継ぎ）
#   ai status                      → 現在の状態を表示
#   ai doctor                      → 移行後の復元前チェック
#   ai works                       → 保存済み current work を一覧表示
#   ai work ai基盤                 → キーワード一致の current work を切り替え
#   ai batches                     → 保存済み batch queue を一覧表示
#   ai batch start 面談JSON --launch → batch を current work に接続して起動
#   ai sessions 導線              → 保存済みセッションを検索
#   ai restore 導線ツール         → キーワードからセッション再開
#   ai restore --fork 019c...      → セッションを分岐復元
#   ai pin 導線ツール 019c...      → 復元用の別名を保存
#   ai pins                        → 保存済み別名を一覧表示
#   ai "導線のセッションを復元したい" → 日本語の自然文で復元

set -euo pipefail

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_SOURCE" ]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
    SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
    if [[ "$SCRIPT_SOURCE" != /* ]]; then
        SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
    fi
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
PROJECT_DIR_DEFAULT="$(cd "$SCRIPT_DIR/../.." && pwd)"

resolve_command_path() {
    local explicit_path="${1:-}"
    local command_name="${2:-}"
    local fallback_path="${3:-}"

    if [ -n "$explicit_path" ] && [ -x "$explicit_path" ]; then
        printf '%s\n' "$explicit_path"
        return 0
    fi

    if [ -n "$command_name" ] && command -v "$command_name" >/dev/null 2>&1; then
        command -v "$command_name"
        return 0
    fi

    if [ -n "$fallback_path" ] && [ -x "$fallback_path" ]; then
        printf '%s\n' "$fallback_path"
        return 0
    fi

    printf '%s\n' ""
    return 0
}

PROJECT_DIR="${AI_PROJECT_DIR:-$PROJECT_DIR_DEFAULT}"
CODEX_CMD="$(resolve_command_path "${AI_CODEX_CMD:-}" "codex" "$HOME/.npm-global/bin/codex")"
CLAUDE_CMD="$(resolve_command_path "${AI_CLAUDE_CMD:-}" "claude" "$HOME/.local/bin/claude")"
ROOT_HANDOFF_FILE="$PROJECT_DIR/.ai_handoff.md"
LEGACY_HANDOFF_FILE="$PROJECT_DIR/Master/output/ai_handoff.md"
STATE_FILE="$PROJECT_DIR/System/data/ai_router/state.json"
LEGACY_STATE_FILE="$HOME/.ai_state.json"
WORK_STATE_HELPER="$PROJECT_DIR/System/scripts/ai_work_state.py"
SESSION_STATE_HELPER="$PROJECT_DIR/System/scripts/ai_session_state.py"
BATCH_STATE_HELPER="$PROJECT_DIR/System/scripts/ai_batch_state.py"
CODEX_SESSIONS_DIR="$HOME/.codex/sessions"
CLAUDE_HISTORY_FILE="$HOME/.claude/history.jsonl"
SESSION_ALIAS_FILE="$PROJECT_DIR/Master/output/session_aliases.json"
SESSION_INDEX_FILE="$PROJECT_DIR/Master/output/session_restore_index.json"

tool_cmd_for() {
    case "${1:-}" in
        codex)
            printf '%s\n' "$CODEX_CMD"
            ;;
        claude)
            printf '%s\n' "$CLAUDE_CMD"
            ;;
        *)
            printf '%s\n' ""
            ;;
    esac
}

ensure_tool_available() {
    local tool="${1:-}"
    local cmd_path
    local env_name=""
    cmd_path="$(tool_cmd_for "$tool")"
    if [ -n "$cmd_path" ] && [ -x "$cmd_path" ]; then
        return 0
    fi

    case "$tool" in
        codex)
            env_name="AI_CODEX_CMD"
            ;;
        claude)
            env_name="AI_CLAUDE_CMD"
            ;;
    esac

    echo "必要な実行ファイルが見つかりません: $tool" >&2
    echo "確認候補:" >&2
    echo "  - PATH に $tool が入っているか" >&2
    if [ -n "$env_name" ]; then
        echo "  - $env_name で実行ファイルを指定しているか" >&2
    fi
    echo "  - ai doctor で解決結果を確認する" >&2
    return 1
}

doctor_runtime() {
    local failures=0
    local state_json current_work_id current_tool handoff_file

    echo "=== ai doctor ==="
    echo "project_dir: $PROJECT_DIR"
    if [ -d "$PROJECT_DIR" ]; then
        echo "  status: ok"
    else
        echo "  status: missing"
        failures=$((failures + 1))
    fi

    for helper in "$WORK_STATE_HELPER" "$SESSION_STATE_HELPER" "$BATCH_STATE_HELPER"; do
        echo "helper: $helper"
        if [ -f "$helper" ]; then
            echo "  status: ok"
        else
            echo "  status: missing"
            failures=$((failures + 1))
        fi
    done

    echo "codex_cmd: ${CODEX_CMD:-not found}"
    if [ -n "$CODEX_CMD" ] && [ -x "$CODEX_CMD" ]; then
        echo "  status: ok"
    else
        echo "  status: missing"
        failures=$((failures + 1))
    fi

    echo "claude_cmd: ${CLAUDE_CMD:-not found}"
    if [ -n "$CLAUDE_CMD" ] && [ -x "$CLAUDE_CMD" ]; then
        echo "  status: ok"
    else
        echo "  status: missing"
        failures=$((failures + 1))
    fi

    echo "codex_sessions: $CODEX_SESSIONS_DIR"
    if [ -d "$CODEX_SESSIONS_DIR" ]; then
        echo "  status: ok"
    else
        echo "  status: missing"
        failures=$((failures + 1))
    fi

    echo "claude_history: $CLAUDE_HISTORY_FILE"
    if [ -f "$CLAUDE_HISTORY_FILE" ]; then
        echo "  status: ok"
    else
        echo "  status: missing"
    fi

    handoff_file="$(get_handoff_file)"
    echo "handoff_file: $handoff_file"
    if [ -f "$handoff_file" ]; then
        echo "  status: ok"
    else
        echo "  status: missing"
        failures=$((failures + 1))
    fi

    echo "session_aliases: $SESSION_ALIAS_FILE"
    if [ -f "$SESSION_ALIAS_FILE" ]; then
        echo "  status: ok"
    else
        echo "  status: missing"
        failures=$((failures + 1))
    fi

    echo "session_index: $SESSION_INDEX_FILE"
    if [ -f "$SESSION_INDEX_FILE" ]; then
        echo "  status: ok"
    else
        echo "  status: missing"
        failures=$((failures + 1))
    fi

    if [ -f "$STATE_FILE" ]; then
        state_json="$(work_state_status_json)"
        current_work_id="$(json_get "$state_json" "current_work_id")"
        current_tool="$(json_get "$state_json" "current_tool")"
        echo "current_tool: ${current_tool:-none}"
        echo "current_work_id: ${current_work_id:-none}"
    else
        echo "state_file: missing ($STATE_FILE)"
        failures=$((failures + 1))
    fi

    echo "override_env:"
    echo "  AI_PROJECT_DIR"
    echo "  AI_CODEX_CMD"
    echo "  AI_CLAUDE_CMD"

    if [ "$failures" -gt 0 ]; then
        echo "doctor_result: fail ($failures)"
        return 1
    fi

    echo "doctor_result: ok"
    return 0
}

# ============================================================
# 状態管理
# ============================================================
get_current_tool() {
    local state_json
    state_json="$(work_state_status_json)"
    json_get "$state_json" "current_tool"
}

set_current_tool() {
    local tool="$1"
    local work_id="${2:-}"
    if [ -z "$work_id" ]; then
        work_id="$(get_current_work_id)"
    fi

    if [ -n "$work_id" ]; then
        python3 "$WORK_STATE_HELPER" activate-work --work-id "$work_id" --tool "$tool" >/dev/null 2>&1 || true
    else
        python3 "$WORK_STATE_HELPER" prepare --prompt "" --tool "$tool" >/dev/null 2>&1 || true
    fi
}

get_handoff_file() {
    if [ -f "$ROOT_HANDOFF_FILE" ]; then
        echo "$ROOT_HANDOFF_FILE"
    elif [ -f "$LEGACY_HANDOFF_FILE" ]; then
        echo "$LEGACY_HANDOFF_FILE"
    else
        echo "$ROOT_HANDOFF_FILE"
    fi
}

work_state_status_json() {
    python3 "$WORK_STATE_HELPER" status 2>/dev/null || echo "{}"
}

json_get() {
    local json_text="${1:-}"
    local field="$2"
    if [ -z "$json_text" ]; then
        json_text="{}"
    fi
    python3 - "$json_text" "$field" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
field = sys.argv[2]
value = payload.get(field, "")
if isinstance(value, (dict, list)):
    print(json.dumps(value, ensure_ascii=False))
else:
    print(value)
PY
}

json_current_work_field() {
    local json_text="${1:-}"
    local field="$2"
    if [ -z "$json_text" ]; then
        json_text="{}"
    fi
    python3 - "$json_text" "$field" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
current = payload.get("current_work") or {}
value = current.get(sys.argv[2], "")
if isinstance(value, (dict, list)):
    print(json.dumps(value, ensure_ascii=False))
else:
    print(value)
PY
}

get_current_work_id() {
    local state_json
    state_json="$(work_state_status_json)"
    json_get "$state_json" "current_work_id"
}

prepare_work_context() {
    local prompt="${1:-}"
    local tool="${2:-auto}"
    python3 "$WORK_STATE_HELPER" prepare --prompt "$prompt" --tool "$tool"
}

activate_session_work() {
    local session_id="$1"
    local tool="$2"
    local preview="${3:-}"
    python3 "$WORK_STATE_HELPER" activate-session --session-id "$session_id" --tool "$tool" --preview "$preview"
}

sync_root_handoff_to_work() {
    python3 "$WORK_STATE_HELPER" sync-root >/dev/null 2>&1 || true
}

record_current_session_link() {
    local session_id="$1"
    local tool="$2"
    local preview="${3:-}"
    local session_json="${4:-{}}"
    python3 "$WORK_STATE_HELPER" record-session --session-id "$session_id" --tool "$tool" --preview "$preview" --session-json "$session_json" >/dev/null 2>&1 || true
}

compact_current_handoff_if_needed() {
    local state_json current_work_id compaction_required
    state_json="$(work_state_status_json)"
    current_work_id="$(json_get "$state_json" "current_work_id")"
    compaction_required="$(json_current_work_field "$state_json" "compaction_required")"
    if [ -z "$current_work_id" ]; then
        return 0
    fi
    if [ "$compaction_required" = "True" ] || [ "$compaction_required" = "true" ]; then
        python3 "$WORK_STATE_HELPER" compact-handoff --work-id "$current_work_id" >/dev/null 2>&1 || true
    fi
}

session_state_latest_json() {
    local tool="$1"
    python3 "$SESSION_STATE_HELPER" latest --tool "$tool"
}

session_state_resolve_json() {
    local query="$1"
    python3 "$SESSION_STATE_HELPER" resolve --query "$query"
}

list_work_records() {
    local query="${1:-}"
    local limit="${2:-20}"
    python3 "$WORK_STATE_HELPER" list-works --query "$query" --limit "$limit"
}

resolve_work_record_json() {
    local query="${1:-}"
    local limit="${2:-5}"
    python3 "$WORK_STATE_HELPER" resolve-work --query "$query" --limit "$limit"
}

list_batch_records_json() {
    local query="${1:-}"
    local limit="${2:-20}"
    python3 "$BATCH_STATE_HELPER" list --query "$query" --limit "$limit"
}

list_skill_candidate_records_json() {
    local query="${1:-}"
    local limit="${2:-20}"
    python3 "$BATCH_STATE_HELPER" list-skill-candidates --query "$query" --limit "$limit"
}

resolve_batch_record_json() {
    local query="${1:-}"
    local limit="${2:-5}"
    python3 "$BATCH_STATE_HELPER" resolve --query "$query" --limit "$limit"
}

show_batch_record_json() {
    local batch_id="$1"
    local item_limit="${2:-10}"
    python3 "$BATCH_STATE_HELPER" show --batch-id "$batch_id" --item-limit "$item_limit"
}

get_current_batch_id() {
    local state_json
    state_json="$(work_state_status_json)"
    json_current_work_field "$state_json" "current_batch_id"
}

ensure_current_batch_item() {
    local state_json current_work_id current_batch_id current_batch_item_id current_tool
    state_json="$(work_state_status_json)"
    current_work_id="$(json_get "$state_json" "current_work_id")"
    current_batch_id="$(json_current_work_field "$state_json" "current_batch_id")"
    current_batch_item_id="$(json_current_work_field "$state_json" "current_batch_item_id")"
    current_tool="$(json_get "$state_json" "current_tool")"
    if [ -z "$current_work_id" ] || [ -z "$current_batch_id" ] || [ -n "$current_batch_item_id" ]; then
        return 0
    fi
    python3 "$BATCH_STATE_HELPER" claim-next --batch-id "$current_batch_id" --work-id "$current_work_id" --tool "$current_tool" >/dev/null 2>&1 || true
}

read_current_batch_item_json() {
    local state_json current_batch_id
    state_json="$(work_state_status_json)"
    current_batch_id="$(json_current_work_field "$state_json" "current_batch_id")"
    if [ -z "$current_batch_id" ]; then
        echo "{}"
        return 0
    fi
    python3 "$BATCH_STATE_HELPER" show --batch-id "$current_batch_id" --item-limit 1 --only-active
}

show_current_work() {
    local state_json current_work_id current_tool current_work_title current_handoff_path
    state_json="$(work_state_status_json)"
    current_work_id="$(json_get "$state_json" "current_work_id")"
    if [ -z "$current_work_id" ]; then
        echo "現在の仕事はありません。"
        return 1
    fi
    current_tool="$(json_get "$state_json" "current_tool")"
    current_work_title="$(json_current_work_field "$state_json" "title")"
    current_handoff_path="$(json_current_work_field "$state_json" "handoff_path")"
    echo "current work: $current_work_id"
    echo "概要: ${current_work_title:-なし}"
    echo "担当ツール: ${current_tool:-なし}"
    echo "正本 handoff: ${current_handoff_path:-なし}"
}

activate_work_selection() {
    local query="${1:-}"
    local resolved_json selected_work_id selected_tool candidate_count activate_json
    local activated_work_id activated_tool activated_title activated_handoff_path

    if [ -z "$query" ]; then
        show_current_work
        return $?
    fi

    resolved_json="$(resolve_work_record_json "$query" "5")"
    selected_work_id="$(json_get "$resolved_json" "selected_work_id")"
    selected_tool="$(json_get "$resolved_json" "selected_tool")"
    candidate_count="$(json_get "$resolved_json" "candidate_count")"

    if [ -z "$selected_work_id" ]; then
        if [ "${candidate_count:-0}" = "0" ]; then
            echo "一致する仕事はありません: $query"
            return 1
        else
            echo "一致候補が複数あります: $query"
            list_work_records "$query" "10"
            return 1
        fi
    fi

    activate_json="$(python3 "$WORK_STATE_HELPER" activate-work --work-id "$selected_work_id" --tool "$selected_tool")"
    activated_work_id="$(json_get "$activate_json" "current_work_id")"
    activated_tool="$(json_get "$activate_json" "selected_tool")"
    activated_title="$(json_current_work_field "$activate_json" "title")"
    activated_handoff_path="$(json_current_work_field "$activate_json" "handoff_path")"

    echo "current work を切り替えました。"
    echo "work_id: ${activated_work_id:-なし}"
    echo "概要: ${activated_title:-なし}"
    echo "担当ツール: ${activated_tool:-なし}"
    echo "正本 handoff: ${activated_handoff_path:-なし}"
}

list_batch_records() {
    local query="${1:-}"
    local limit="${2:-20}"
    local payload
    payload="$(list_batch_records_json "$query" "$limit")"
    python3 - "$payload" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
batches = payload.get("batches") or []

if not batches:
    query = payload.get("query", "")
    if query:
        print(f"一致する batch はありません: {query}")
    else:
        print("登録された batch はまだありません。")
    sys.exit(0)

print("updated_at    tool     batch_id                summary")
print("-" * 120)
for batch in batches:
    updated_at = str(batch.get("updated_at") or "-")
    if len(updated_at) >= 16:
        updated_at = updated_at[5:16].replace("T", " ")
    tool = batch.get("preferred_tool") or "-"
    batch_id = batch.get("batch_id") or "-"
    summary = batch.get("summary") or batch.get("title") or batch_id
    print(f"{updated_at:<13} {tool:<8} {batch_id:<23} {summary}")
PY
}

list_skill_candidate_records() {
    local query="${1:-}"
    local limit="${2:-20}"
    local payload
    payload="$(list_skill_candidate_records_json "$query" "$limit")"
    python3 - "$payload" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
rows = payload.get("skill_candidates") or []

if not rows:
    query = payload.get("query", "")
    if query:
        print(f"一致する skill 候補はありません: {query}")
    else:
        print("skill 候補はまだありません。")
    sys.exit(0)

print("updated_at    status   batch_id                summary")
print("-" * 120)
for row in rows:
    updated_at = str(row.get("updated_at") or "-")
    if len(updated_at) >= 16:
        updated_at = updated_at[5:16].replace("T", " ")
    status = row.get("status") or "-"
    batch_id = row.get("batch_id") or "-"
    summary = row.get("summary") or row.get("title") or batch_id
    print(f"{updated_at:<13} {status:<8} {batch_id:<23} {summary}")
PY
}

resolve_batch_id() {
    local query="${1:-}"
    local resolved_json batch_id
    resolved_json="$(resolve_batch_record_json "$query" "5")"
    batch_id="$(json_get "$resolved_json" "selected_batch_id")"
    if [ -n "$batch_id" ]; then
        printf '%s\n' "$batch_id"
        return 0
    fi
    local candidate_count
    candidate_count="$(json_get "$resolved_json" "candidate_count")"
    if [ "${candidate_count:-0}" = "0" ]; then
        echo "一致する batch はありません: $query" >&2
    else
        echo "一致候補が複数あります: $query" >&2
        list_batch_records "$query" "10" >&2
    fi
    return 1
}

show_batch_record() {
    local query="${1:-}"
    local batch_id payload
    if [ -z "$query" ]; then
        batch_id="$(get_current_batch_id)"
    else
        batch_id="$(resolve_batch_id "$query")" || return 1
    fi
    if [ -z "$batch_id" ]; then
        echo "current batch はありません。"
        return 1
    fi
    payload="$(show_batch_record_json "$batch_id" "10")"
    python3 - "$payload" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
items = payload.get("items") or []
counts = payload.get("counts") or {}
active = payload.get("active_item") or {}
candidate = payload.get("skill_candidate") or {}

if not batch:
    print("batch が見つかりません。")
    sys.exit(1)

print(f"batch_id: {batch.get('batch_id','')}")
print(f"概要: {batch.get('title','')}")
print(f"タイプ: {batch.get('batch_type','-')}")
print(f"担当ツール: {batch.get('preferred_tool','-')}")
print(f"進捗: {counts.get('pending',0)} pending / {counts.get('running',0)} running / {counts.get('completed',0)} done / {counts.get('failed',0)} failed")
print(f"紐づく work: {batch.get('work_id','-') or '-'}")
if batch.get("schema_hint"):
    print(f"スキーマ: {batch.get('schema_hint','')}")
if batch.get("source"):
    print(f"ソース: {batch.get('source','')}")
if batch.get("source_last_sync_summary"):
    print(f"source sync: {batch.get('source_last_sync_summary','')}")
if active:
    print(f"実行中 item: {active.get('item_id','')} / {active.get('title','')}")
    if active.get("source_ref"):
        print(f"  source_ref: {active.get('source_ref','')}")
    if active.get("payload_preview"):
        print(f"  payload: {active.get('payload_preview','')}")
if candidate:
    print(f"skill候補: {candidate.get('status','-')} / {candidate.get('summary','')}")
    missing = candidate.get("missing_requirements") or []
    if missing:
        print(f"  不足: {missing[0]}")
if items:
    print("")
    print("items:")
    for item in items[:10]:
        status = item.get("status","-")
        item_id = item.get("item_id","-")
        title = item.get("title","")
        print(f"- [{status}] {item_id} {title}")
PY
}

start_batch_work() {
    local query="${1:-}"
    local launch_flag="${2:-0}"
    if [ -z "$query" ]; then
        echo "使い方: ai batch start <batch_id|キーワード> [--launch]"
        return 1
    fi

    local batch_id batch_json batch_title batch_tool linked_work_id prepared_json current_work_id state_json batch_source
    batch_id="$(resolve_batch_id "$query")" || return 1
    batch_json="$(show_batch_record_json "$batch_id" "1")"
    batch_title="$(python3 - "$batch_json" <<'PY'
import json, sys
payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
print(batch.get("title", ""))
PY
)"
    batch_tool="$(python3 - "$batch_json" <<'PY'
import json, sys
payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
print(batch.get("preferred_tool", "codex"))
PY
)"
    linked_work_id="$(python3 - "$batch_json" <<'PY'
import json, sys
payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
print(batch.get("work_id", ""))
PY
)"
    batch_source="$(python3 - "$batch_json" <<'PY'
import json, sys
payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
print(batch.get("source", ""))
PY
)"

    if [ -n "$batch_source" ]; then
        sync_batch_source_json "$batch_id" >/dev/null
        batch_json="$(show_batch_record_json "$batch_id" "1")"
    fi

    if [ -n "$linked_work_id" ]; then
        python3 "$WORK_STATE_HELPER" activate-work --work-id "$linked_work_id" --tool "$batch_tool" >/dev/null
        current_work_id="$linked_work_id"
    else
        prepared_json="$(prepare_work_context "$batch_title" "$batch_tool")"
        current_work_id="$(json_get "$prepared_json" "current_work_id")"
        python3 "$BATCH_STATE_HELPER" attach-work --batch-id "$batch_id" --work-id "$current_work_id" >/dev/null
    fi

    ensure_current_batch_item
    state_json="$(work_state_status_json)"
    echo "batch を current work に接続しました。"
    echo "work_id: $(json_get "$state_json" "current_work_id")"
    echo "batch_id: $batch_id"
    echo "概要: ${batch_title:-なし}"
    show_batch_record "$batch_id"

    if [ "$launch_flag" = "1" ]; then
        if [ "$batch_tool" = "claude" ]; then
            launch_claude ""
        else
            launch_codex ""
        fi
    fi
}

show_current_batch_item_packet() {
    local payload
    payload="$(read_current_batch_item_json)"
    python3 - "$payload" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
item = payload.get("active_item") or {}

if not batch:
    print("current batch はありません。")
    sys.exit(1)

print(f"batch: {batch.get('batch_id','')} / {batch.get('title','')}")
if not item:
    print("実行中 item はありません。`ai batch next` で次件を取得できます。")
    sys.exit(0)

print(f"item: {item.get('item_id','')} / {item.get('title','')}")
if item.get("source_ref"):
    print(f"source_ref: {item.get('source_ref','')}")
if item.get("payload_preview"):
    print(f"payload: {item.get('payload_preview','')}")
print(f"完了記録: ai batch done {item.get('item_id','')} --summary \"...\"")
print(f"失敗記録: ai batch fail {item.get('item_id','')} --error \"...\"")
PY
}

claim_next_batch_item() {
    local query="${1:-}"
    local state_json current_work_id current_batch_id current_tool payload batch_id batch_json linked_work_id batch_tool batch_source
    state_json="$(work_state_status_json)"
    current_work_id="$(json_get "$state_json" "current_work_id")"
    current_tool="$(json_get "$state_json" "current_tool")"
    if [ -n "$query" ]; then
        batch_id="$(resolve_batch_id "$query")" || return 1
        batch_json="$(show_batch_record_json "$batch_id" "1")"
        linked_work_id="$(python3 - "$batch_json" <<'PY'
import json, sys
payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
print(batch.get("work_id", ""))
PY
)"
        batch_tool="$(python3 - "$batch_json" <<'PY'
import json, sys
payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
print(batch.get("preferred_tool", "codex"))
PY
)"
        batch_source="$(python3 - "$batch_json" <<'PY'
import json, sys
payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
print(batch.get("source", ""))
PY
)"
        if [ -n "$linked_work_id" ] && [ "$linked_work_id" != "$current_work_id" ]; then
            python3 "$WORK_STATE_HELPER" activate-work --work-id "$linked_work_id" --tool "$batch_tool" >/dev/null
            state_json="$(work_state_status_json)"
            current_work_id="$(json_get "$state_json" "current_work_id")"
            current_tool="$(json_get "$state_json" "current_tool")"
        elif [ -z "$linked_work_id" ] && [ -n "$current_work_id" ]; then
            python3 "$BATCH_STATE_HELPER" attach-work --batch-id "$batch_id" --work-id "$current_work_id" >/dev/null
        fi
    else
        batch_id="$(json_current_work_field "$state_json" "current_batch_id")"
        if [ -n "$batch_id" ]; then
            batch_json="$(show_batch_record_json "$batch_id" "1")"
            batch_source="$(python3 - "$batch_json" <<'PY'
import json, sys
payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
print(batch.get("source", ""))
PY
)"
        fi
    fi
    if [ -z "$batch_id" ]; then
        echo 'current batch がありません。`ai batch start <batch>` を先に実行してください。'
        return 1
    fi
    if [ -n "$batch_source" ]; then
        sync_batch_source_json "$batch_id" >/dev/null
    fi
    payload="$(python3 "$BATCH_STATE_HELPER" claim-next --batch-id "$batch_id" --work-id "$current_work_id" --tool "$current_tool")"
    python3 - "$payload" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
item = payload.get("item") or {}

if not item:
    print(f"pending item はありません: {batch.get('batch_id','')}")
    sys.exit(0)

mode = "新規に取得" if payload.get("claimed_new") else "継続中"
print(f"{mode}: {batch.get('batch_id','')} / {batch.get('title','')}")
print(f"item: {item.get('item_id','')} / {item.get('title','')}")
if item.get("source_ref"):
    print(f"source_ref: {item.get('source_ref','')}")
if item.get("payload_preview"):
    print(f"payload: {item.get('payload_preview','')}")
print(f"完了記録: ai batch done {item.get('item_id','')} --summary \"...\"")
print(f"失敗記録: ai batch fail {item.get('item_id','')} --error \"...\"")
PY
}

complete_current_batch_item() {
    local item_id="${1:-}"
    shift || true
    local summary=""
    local result_ref=""
    while [ $# -gt 0 ]; do
        case "${1:-}" in
            --summary)
                summary="${2:-}"
                shift 2
                ;;
            --result)
                result_ref="${2:-}"
                shift 2
                ;;
            *)
                echo "使い方: ai batch done [item_id] --summary <要約> [--result <参照先>]"
                return 1
                ;;
        esac
    done
    if [ -z "$summary" ]; then
        echo "使い方: ai batch done [item_id] --summary <要約> [--result <参照先>]"
        return 1
    fi
    local state_json batch_id payload
    state_json="$(work_state_status_json)"
    batch_id="$(json_current_work_field "$state_json" "current_batch_id")"
    if [ -z "$batch_id" ]; then
        echo "current batch がありません。"
        return 1
    fi
    payload="$(python3 "$BATCH_STATE_HELPER" complete-item --batch-id "$batch_id" --item-id "$item_id" --summary "$summary" --result-ref "$result_ref")"
    python3 - "$payload" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
if payload.get("error"):
    print(payload["error"])
    sys.exit(1)
batch = payload.get("batch") or {}
item = payload.get("item") or {}
counts = batch.get("counts") or {}
print(f"完了記録: {item.get('item_id','')} / {item.get('title','')}")
print(f"残件数: {counts.get('pending',0)} pending / {counts.get('running',0)} running / {counts.get('completed',0)} done")
PY
}

fail_current_batch_item() {
    local item_id="${1:-}"
    shift || true
    local error_text=""
    while [ $# -gt 0 ]; do
        case "${1:-}" in
            --error)
                error_text="${2:-}"
                shift 2
                ;;
            *)
                echo "使い方: ai batch fail [item_id] --error <理由>"
                return 1
                ;;
        esac
    done
    if [ -z "$error_text" ]; then
        echo "使い方: ai batch fail [item_id] --error <理由>"
        return 1
    fi
    local state_json batch_id payload
    state_json="$(work_state_status_json)"
    batch_id="$(json_current_work_field "$state_json" "current_batch_id")"
    if [ -z "$batch_id" ]; then
        echo "current batch がありません。"
        return 1
    fi
    payload="$(python3 "$BATCH_STATE_HELPER" fail-item --batch-id "$batch_id" --item-id "$item_id" --error "$error_text")"
    python3 - "$payload" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
if payload.get("error"):
    print(payload["error"])
    sys.exit(1)
batch = payload.get("batch") or {}
item = payload.get("item") or {}
counts = batch.get("counts") or {}
print(f"失敗記録: {item.get('item_id','')} / {item.get('title','')}")
print(f"残件数: {counts.get('pending',0)} pending / {counts.get('running',0)} running / {counts.get('failed',0)} failed")
PY
}

release_current_batch_item() {
    local item_id="${1:-}"
    local state_json batch_id payload
    state_json="$(work_state_status_json)"
    batch_id="$(json_current_work_field "$state_json" "current_batch_id")"
    if [ -z "$batch_id" ]; then
        echo "current batch がありません。"
        return 1
    fi
    payload="$(python3 "$BATCH_STATE_HELPER" release-item --batch-id "$batch_id" --item-id "$item_id")"
    python3 - "$payload" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
if payload.get("error"):
    print(payload["error"])
    sys.exit(1)
item = payload.get("item") or {}
print(f"pending に戻しました: {item.get('item_id','')} / {item.get('title','')}")
PY
}

create_batch_record() {
    local title="$1"
    local tool="${2:-codex}"
    local batch_type="${3:-}"
    local source="${4:-}"
    local schema_hint="${5:-}"
    python3 "$BATCH_STATE_HELPER" create --title "$title" --tool "$tool" --type "$batch_type" --source "$source" --schema-hint "$schema_hint"
}

