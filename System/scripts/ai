    local path="$2"
    python3 "$BATCH_STATE_HELPER" import-jsonl --batch-id "$batch_id" --path "$path"
}

sync_batch_source_json() {
    local batch_id="$1"
    python3 "$BATCH_STATE_HELPER" sync-source --batch-id "$batch_id"
}

read_handoff_snapshot_json() {
    local handoff_file
    handoff_file="$(get_handoff_file)"

    python3 - "$handoff_file" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])

sections = {
    "purpose": "",
    "confirmed": [],
    "completed": [],
    "remaining": [],
    "decisions": [],
    "references": [],
    "changed_files": [],
    "next": [],
}

if not path.exists():
    print(json.dumps(sections, ensure_ascii=False))
    sys.exit(0)

current = None
for raw_line in path.read_text(errors="replace").splitlines():
    line = raw_line.rstrip()
    if line.startswith("## "):
        title = line[3:].strip()
        current = {
            "目的": "purpose",
            "確定事項": "confirmed",
            "完了したこと": "completed",
            "未完了": "remaining",
            "判断とその理由（最重要）": "decisions",
            "参照先": "references",
            "変更したファイル": "changed_files",
            "次の担当へ": "next",
        }.get(title)
        continue

    if not current:
        continue

    stripped = line.strip()
    if not stripped:
        continue

    if current == "purpose":
        sections["purpose"] = f"{sections['purpose']} {stripped}".strip()
        continue

    if stripped.startswith("- "):
        sections[current].append(stripped[2:].strip())
    elif sections[current]:
        sections[current][-1] = f"{sections[current][-1]} {stripped}".strip()

print(json.dumps(sections, ensure_ascii=False))
PY
}

read_session_record_json() {
    local query="$1"
    python3 - "$SESSION_ALIAS_FILE" "$SESSION_INDEX_FILE" "$query" <<'PY'
import json
import re
import sys
from pathlib import Path

alias_path = Path(sys.argv[1])
index_path = Path(sys.argv[2])
query = sys.argv[3]
query_lc = query.lower()
is_sid = bool(re.fullmatch(r"[0-9a-fA-F-]{36}", query))

def load_json(path):
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text())
    except Exception:
        return {}

aliases = load_json(alias_path)
index = load_json(index_path)
aliases_by_sid = {}
for alias, record in aliases.items():
    sid = record.get("session_id")
    if sid:
        aliases_by_sid.setdefault(sid, []).append(alias)

def merged_record(sid, preferred_alias=None):
    if not sid:
        return {}
    record = {}
    if isinstance(index.get(sid), dict):
        record.update(index[sid])
    aliases_for_sid = aliases_by_sid.get(sid, [])
    alias = preferred_alias or (aliases_for_sid[0] if aliases_for_sid else "")
    if alias and isinstance(aliases.get(alias), dict):
        record.update(aliases[alias])
    if alias:
        record["alias"] = alias
    if aliases_for_sid:
        record["aliases"] = aliases_for_sid
    record["session_id"] = sid
    return record

for alias, record in aliases.items():
    if alias.lower() == query_lc:
        out = merged_record(record.get("session_id"), alias)
        print(json.dumps(out, ensure_ascii=False))
        sys.exit(0)

if is_sid:
    out = merged_record(query)
    if out:
        print(json.dumps(out, ensure_ascii=False))
        sys.exit(0)

print("{}")
PY
}

latest_session_record_json() {
    local tool="$1"
    session_state_latest_json "$tool"
}

verify_session_snapshot_json() {
    local tool="$1"
    local session_id="${2:-}"
    if [ -n "$session_id" ]; then
        python3 "$SESSION_STATE_HELPER" verify --tool "$tool" --session-id "$session_id"
    else
        python3 "$SESSION_STATE_HELPER" verify --tool "$tool"
    fi
}

snapshot_latest_session() {
    local tool="${1:-}"
    local session_id="${2:-}"
    local preview="${3:-}"
    local payload latest_json

    if [ -z "$tool" ] || [ "$tool" = "none" ]; then
        tool="$(get_current_tool)"
    fi
    if [ -z "$tool" ] || [ "$tool" = "none" ]; then
        echo "検証対象のツールがありません。codex か claude を指定してください。"
        return 1
    fi

    if [ -z "$session_id" ] || [ -z "$preview" ]; then
        latest_json="$(latest_session_record_json "$tool")"
        if [ -z "$session_id" ]; then
            session_id="$(python3 -c 'import json,sys; print(json.loads(sys.argv[1] or "{}").get("session_id",""))' "$latest_json")"
        fi
        if [ -z "$preview" ]; then
            preview="$(python3 -c 'import json,sys; print(json.loads(sys.argv[1] or "{}").get("preview",""))' "$latest_json")"
        fi
    fi

    capture_latest_session_snapshot "$tool" "$session_id" "$preview"
    payload="$(verify_session_snapshot_json "$tool" "$session_id")"
    python3 - "$payload" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
session_id = payload.get("session_id", "")
if payload.get("ok"):
    print("session snapshot を保存しました。")
else:
    print("session snapshot の保存結果を確認してください。")
print(f"tool: {payload.get('tool','')}")
print(f"session_id: {session_id or '未検出'}")
print(f"index 保存: {'OK' if payload.get('snapshot_found') else 'NG'}")
print(f"metrics 保存: {'OK' if payload.get('checks', {}).get('session_metrics') else 'NG'}")
print(f"load 保存: {'OK' if payload.get('checks', {}).get('session_load') else 'NG'}")
print(f"work 紐づけ: {'OK' if payload.get('checks', {}).get('work_link') else 'NG'}")
if payload.get("snapshot_title"):
    print(f"snapshot title: {payload.get('snapshot_title','')}")
if payload.get("work_id"):
    print(f"work_id: {payload.get('work_id','')}")
PY
}

upsert_session_snapshot_record() {
    local tool="$1"
    local session_id="$2"
    local preview="${3:-}"
    local handoff_file snapshot_json work_id session_json

    handoff_file="$(get_handoff_file)"
    snapshot_json="$(read_handoff_snapshot_json)"
    work_id="$(get_current_work_id)"
    session_json="${4:-{}}"

    python3 - "$SESSION_INDEX_FILE" "$SESSION_ALIAS_FILE" "$tool" "$session_id" "$preview" "$snapshot_json" "$handoff_file" "$work_id" "$session_json" <<'PY'
import json
import sys
from datetime import datetime
from pathlib import Path

index_path = Path(sys.argv[1])
alias_path = Path(sys.argv[2])
tool = sys.argv[3]
session_id = sys.argv[4]
preview = sys.argv[5]
snapshot = json.loads(sys.argv[6])
handoff_file = sys.argv[7]
work_id = sys.argv[8]

def parse_json_text(raw, default):
    text = str(raw or "").strip()
    if not text:
        return default
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        pass
    decoder = json.JSONDecoder()
    try:
        value, _ = decoder.raw_decode(text)
        return value
    except json.JSONDecodeError:
        for line in reversed([line.strip() for line in text.splitlines() if line.strip()]):
            try:
                return json.loads(line)
            except Exception:
                continue
    return default

snapshot = parse_json_text(sys.argv[6], {})
session_data = parse_json_text(sys.argv[9], {})

FIELDS = (
    ("purpose", ""),
    ("confirmed", []),
    ("completed", []),
    ("remaining", []),
    ("decisions", []),
    ("references", []),
    ("changed_files", []),
    ("next", []),
)

def load_json(path):
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text())
    except Exception:
        return {}

def has_snapshot_content(data):
    if data.get("purpose"):
        return True
    return any(data.get(key) for key, _ in FIELDS if key != "purpose")

def merge_snapshot(target, data):
    if not has_snapshot_content(data):
        return target
    for key, default in FIELDS:
        value = data.get(key, default)
        if isinstance(default, list):
            target[key] = list(value or [])
        else:
            target[key] = value or ""
    return target

def merge_session_data(target, data):
    if not isinstance(data, dict):
        return target
    metrics = data.get("metrics")
    load = data.get("load")
    start = data.get("start")
    end = data.get("end")
    preview = data.get("preview")
    if isinstance(metrics, dict) and metrics:
        target["session_metrics"] = metrics
    if isinstance(load, dict) and load:
        target["session_load"] = load
        if load.get("should_fork") is not None:
            target["auto_fork_recommended"] = bool(load.get("should_fork"))
    if start:
        target["session_start"] = start
    if end:
        target["session_end"] = end
    if preview and not target.get("title"):
        target["title"] = preview
    return target

def apply_preview_title(target, preview):
    preview = " ".join(str(preview or "").split())
    current = " ".join(str(target.get("title", "")).split())
    if not preview:
        return
    if not current:
        target["title"] = preview
        return
    if len(preview) <= len(current) and " / " not in preview:
        target["title"] = preview

now = datetime.now().isoformat()
index = load_json(index_path)
aliases = load_json(alias_path)

record = dict(index.get(session_id, {}))
record["tool"] = tool or record.get("tool", "")
record["session_id"] = session_id
record["updated_at"] = now
apply_preview_title(record, preview)
if handoff_file:
    record["handoff_file"] = handoff_file
if work_id:
    record["work_id"] = work_id
record = merge_snapshot(record, snapshot)
record = merge_session_data(record, session_data)

index_path.parent.mkdir(parents=True, exist_ok=True)
index[session_id] = record
index_path.write_text(json.dumps(index, ensure_ascii=False, indent=2, sort_keys=True) + "\n")

updated_aliases = False
for alias, alias_record in aliases.items():
    if alias_record.get("session_id") != session_id:
        continue
    merged = dict(alias_record)
    merged["tool"] = tool or merged.get("tool", "")
    merged["session_id"] = session_id
    merged["updated_at"] = now
    apply_preview_title(merged, preview)
    if handoff_file:
        merged["handoff_file"] = handoff_file
    if work_id:
        merged["work_id"] = work_id
    merged = merge_snapshot(merged, snapshot)
    merged = merge_session_data(merged, session_data)
    aliases[alias] = merged
    updated_aliases = True

if updated_aliases:
    alias_path.parent.mkdir(parents=True, exist_ok=True)
    alias_path.write_text(json.dumps(aliases, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
PY
}

capture_latest_session_snapshot() {
    local tool="$1"
    local session_id="${2:-}"
    local preview="${3:-}"
    local latest_json session_json

    if [ -z "$session_id" ] || [ -z "$preview" ]; then
        latest_json="$(latest_session_record_json "$tool")"
        if [ -z "$session_id" ]; then
            session_id="$(python3 -c 'import json,sys; print(json.loads(sys.argv[1] or "{}").get("session_id",""))' "$latest_json")"
        fi
        if [ -z "$preview" ]; then
            preview="$(python3 -c 'import json,sys; print(json.loads(sys.argv[1] or "{}").get("preview",""))' "$latest_json")"
        fi
        session_json="$latest_json"
    else
        session_json="$(session_state_resolve_json "$session_id" 2>/dev/null || echo "{}")"
    fi

    if [ -z "$session_id" ]; then
        return 0
    fi

    sync_root_handoff_to_work
    record_current_session_link "$session_id" "$tool" "$preview" "$session_json"
    upsert_session_snapshot_record "$tool" "$session_id" "$preview" "$session_json"
}

build_restore_prompt() {
    local record_json="$1"
    local extra_prompt="${2:-}"

    python3 - "$record_json" "$extra_prompt" <<'PY'
import json
import sys

record = json.loads(sys.argv[1] or "{}")
extra_prompt = sys.argv[2].strip()

def clean(text, limit=220):
    text = " ".join(str(text).split())
    if not text:
        return ""
    return text[:limit]

def bullet_lines(items, limit):
    out = []
    for item in items[:limit]:
        text = clean(item, 180)
        if text:
            out.append(f"- {text}")
    return out

parts = []
alias = clean(record.get("alias", ""), 80)
purpose = clean(record.get("purpose", ""), 220)
completed = bullet_lines(record.get("completed") or [], 2)
remaining = bullet_lines(record.get("remaining") or [], 3)
next_items = bullet_lines(record.get("next") or [], 2)

if alias or purpose or completed or remaining or next_items:
    lines = ["前回の復元メモを踏まえて続けてください。"]
    if alias:
        lines.append(f"別名: {alias}")
    if purpose:
        lines.append(f"目的: {purpose}")
    if completed:
        lines.append("完了:")
        lines.extend(completed)
    if remaining:
        lines.append("未完了:")
        lines.extend(remaining)
    if next_items:
        lines.append("次にやること:")
        lines.extend(next_items)
    parts.append("\n".join(lines))

if extra_prompt:
    parts.append(extra_prompt)

print("\n\n".join(part for part in parts if part))
PY
}

is_session_id() {
    [[ "$1" =~ ^[0-9a-fA-F-]{36}$ ]]
}

list_sessions() {
    local query="${1:-}"
    local limit="${2:-20}"
    python3 "$SESSION_STATE_HELPER" list --query "$query" --limit "$limit"
}

resolve_session() {
    local query="$1"
    local resolved_json
    resolved_json="$(session_state_resolve_json "$query")" || return $?
    python3 - "$resolved_json" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
print(f"{payload.get('tool','')}\t{payload.get('session_id','')}\t{payload.get('preview','')}")
PY
}

restore_session() {
    local mode="resume"
    local force_resume="0"
    while [ $# -gt 0 ]; do
        case "${1:-}" in
            --fork)
                mode="fork"
                shift
                ;;
            --force-resume)
                force_resume="1"
                shift
                ;;
            *)
                break
                ;;
        esac
    done

    if [ $# -lt 1 ]; then
        echo "使い方: ai restore [--fork] [--force-resume] <session_id|キーワード> [追加プロンプト]"
        return 1
    fi

    local query="$1"
    shift
    local extra_prompt="${*:-}"
    local resolved_json resolved

    if ! resolved_json="$(session_state_resolve_json "$query")"; then
        return 1
    fi
    resolved="$(python3 - "$resolved_json" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
print(f"{payload.get('tool','')}\t{payload.get('session_id','')}\t{payload.get('preview','')}")
PY
)"

    local tool session_id preview record_json overview restore_prompt rc work_json work_context_prompt combined_extra_prompt load_context_prompt auto_fork_note
    local should_fork load_summary
    tool=$(printf '%s' "$resolved" | cut -f1)
    session_id=$(printf '%s' "$resolved" | cut -f2)
    preview=$(printf '%s' "$resolved" | cut -f3-)
    record_json="$(python3 - "$(read_session_record_json "$session_id")" "$resolved_json" <<'PY'
import json
import sys

base = json.loads(sys.argv[1] or "{}")
resolved = json.loads(sys.argv[2] or "{}")
if isinstance(resolved, dict):
    for key in ("tool", "session_id", "preview", "start", "end", "metrics", "load"):
        if resolved.get(key):
            mapped = {
                "metrics": "session_metrics",
                "load": "session_load",
                "start": "session_start",
                "end": "session_end",
            }.get(key, key)
            base[mapped] = resolved[key]
    record = resolved.get("record")
    if isinstance(record, dict):
        for key, value in record.items():
            if value and key not in base:
                base[key] = value
print(json.dumps(base, ensure_ascii=False))
PY
)"

    should_fork="$(python3 - "$record_json" <<'PY'
import json
import sys
record = json.loads(sys.argv[1] or "{}")
load = record.get("session_load") or {}
print("1" if load.get("should_fork") else "0")
PY
)"
    load_summary="$(python3 - "$record_json" <<'PY'
import json
import sys
record = json.loads(sys.argv[1] or "{}")
load = record.get("session_load") or {}
print(load.get("summary", ""))
PY
)"

    if [ "$mode" = "resume" ] && [ "$force_resume" != "1" ] && [ "$should_fork" = "1" ]; then
        mode="fork"
        auto_fork_note="長セッション判定のため fork で再開します。"
    fi

    overview="$(python3 - "$record_json" "$tool" "$session_id" "$preview" "$mode" "$auto_fork_note" <<'PY'
import json
import sys

record = json.loads(sys.argv[1] or "{}")
tool = sys.argv[2]
session_id = sys.argv[3]
preview = sys.argv[4]
mode = sys.argv[5]
auto_fork_note = sys.argv[6]

def clean(text, limit=220):
    text = " ".join(str(text).split())
    if not text:
        return ""
    return text[:limit]

lines = [f"復元対象: {tool} {session_id}"]
alias = clean(record.get("alias", ""), 80)
title = clean(record.get("title", ""), 120)
purpose = clean(record.get("purpose", ""), 220)
completed = [clean(item, 160) for item in (record.get("completed") or []) if clean(item, 160)]
remaining = [clean(item, 160) for item in (record.get("remaining") or []) if clean(item, 160)]
load = record.get("session_load") or {}

if alias:
    lines.append(f"別名: {alias}")
if title and title != preview:
    lines.append(f"概要: {title}")
elif preview:
    lines.append(f"概要: {clean(preview, 120)}")
if purpose:
    lines.append(f"目的: {purpose}")
if completed:
    lines.append(f"完了: {completed[0]}")
if remaining:
    lines.append(f"未完了: {remaining[0]}")
if load.get("summary"):
    lines.append(f"負荷判定: {clean(load.get('summary', ''), 120)}")
lines.append(f"復元方式: {mode}")
if auto_fork_note:
    lines.append(auto_fork_note)

print("\n".join(lines))
PY
    )"
    printf '%s\n' "$overview"
    activate_session_work "$session_id" "$tool" "$preview" >/dev/null 2>&1 || true
    compact_current_handoff_if_needed
    ensure_current_batch_item
    work_json="$(work_state_status_json)"
    work_context_prompt="$(python3 - "$work_json" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
work = payload.get("current_work") or {}
work_id = payload.get("current_work_id") or ""
purpose = " ".join(str(work.get("purpose", "")).split())
handoff = work.get("handoff_path", "")
batch_id = work.get("current_batch_id", "")
batch_title = " ".join(str(work.get("current_batch_title", "")).split())
batch_item_id = work.get("current_batch_item_id", "")
batch_item_title = " ".join(str(work.get("current_batch_item_title", "")).split())
lines = []
if work_id:
    lines.append("現在の仕事正本を優先して続けてください。")
    lines.append(f"- work_id: {work_id}")
if purpose:
    lines.append(f"- 目的: {purpose[:220]}")
if handoff:
    lines.append(f"- 最新 handoff: {handoff}")
if batch_id:
    lines.append(f"- current batch: {batch_id} {batch_title[:80]}")
if batch_item_id:
    lines.append(f"- active item: {batch_item_id} {batch_item_title[:80]}")
print("\n".join(lines))
PY
)"
    load_context_prompt="$(python3 - "$record_json" "$mode" <<'PY'
import json
import sys

record = json.loads(sys.argv[1] or "{}")
mode = sys.argv[2]
load = record.get("session_load") or {}
lines = []
if load.get("should_compact"):
    lines.append("この案件は長セッション化しているため、古い会話全文ではなく current work handoff を正本として続けてください。")
    lines.append("- 区切りごとに `.ai_handoff.md` を更新し、圧縮後の状態だけを残す")
if mode == "fork":
    lines.append("今回は fork 復元なので、前セッションの詳細を引きずらず current work の最新状態から再構成してください。")
print("\n".join(lines))
PY
)"
    combined_extra_prompt="$(python3 - "$work_context_prompt" "$load_context_prompt" "$extra_prompt" <<'PY'
import sys

parts = ["\n".join(str(arg).splitlines()).strip() for arg in sys.argv[1:]]
print("\n\n".join(part for part in parts if part))
PY
)"
    restore_prompt="$(build_restore_prompt "$record_json" "$combined_extra_prompt")"

    cd "$PROJECT_DIR"

    if [ "$tool" = "codex" ]; then
        ensure_tool_available "codex" || return 1
        set +e
        if [ "$mode" = "fork" ]; then
            if [ -n "$restore_prompt" ]; then
                "$CODEX_CMD" fork "$session_id" "$restore_prompt"
            else
                "$CODEX_CMD" fork "$session_id"
            fi
        else
            if [ -n "$restore_prompt" ]; then
                "$CODEX_CMD" resume "$session_id" "$restore_prompt"
            else
                "$CODEX_CMD" resume "$session_id"
            fi
        fi
        rc=$?
        set -e
    else
        ensure_tool_available "claude" || return 1
        set +e
        if [ "$mode" = "fork" ]; then
            if [ -n "$restore_prompt" ]; then
                "$CLAUDE_CMD" -r "$session_id" --fork-session "$restore_prompt"
            else
                "$CLAUDE_CMD" -r "$session_id" --fork-session
            fi
        else
            if [ -n "$restore_prompt" ]; then
                "$CLAUDE_CMD" -r "$session_id" "$restore_prompt"
            else
                "$CLAUDE_CMD" -r "$session_id"
            fi
        fi
        rc=$?
        set -e
    fi

    capture_latest_session_snapshot "$tool"
    return "$rc"
}

pin_session_alias() {
    if [ $# -lt 2 ]; then
        echo "使い方: ai pin <別名> <session_id|キーワード>"
        return 1
    fi

    local alias="$1"
    shift
    local query="$*"
    local resolved

    if ! resolved=$(resolve_session "$query"); then
        return 1
    fi

    local tool session_id preview record_json
    tool=$(printf '%s' "$resolved" | cut -f1)
    session_id=$(printf '%s' "$resolved" | cut -f2)
    preview=$(printf '%s' "$resolved" | cut -f3-)
    record_json="$(read_session_record_json "$session_id")"

    python3 - "$SESSION_ALIAS_FILE" "$alias" "$tool" "$session_id" "$preview" "$record_json" <<'PY'
import json
import sys
from datetime import datetime
from pathlib import Path

path = Path(sys.argv[1])
alias = sys.argv[2]
tool = sys.argv[3]
session_id = sys.argv[4]
preview = sys.argv[5]
record = json.loads(sys.argv[6] or "{}")

data = {}
if path.exists():
    try:
        data = json.loads(path.read_text())
    except Exception:
        data = {}

path.parent.mkdir(parents=True, exist_ok=True)
entry = dict(data.get(alias, {}))
entry["tool"] = tool
entry["session_id"] = session_id
entry["updated_at"] = datetime.now().isoformat()
if preview:
    entry["title"] = preview

for key in ("purpose", "confirmed", "completed", "remaining", "decisions", "references", "changed_files", "next", "handoff_file"):
    if key in record and record.get(key):
        entry[key] = record[key]

data[alias] = entry
path.write_text(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n")
PY

    echo "別名を保存しました: $alias -> $tool $session_id"
}

list_session_aliases() {
    python3 - "$SESSION_ALIAS_FILE" "$SESSION_INDEX_FILE" <<'PY'
import json
import sys
from pathlib import Path

alias_path = Path(sys.argv[1])
index_path = Path(sys.argv[2])

if not alias_path.exists():
    print("保存済み別名はまだありません。")
    sys.exit(0)

def load_json(path):
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text())
    except Exception:
        return {}

try:
    data = load_json(alias_path)
    index = load_json(index_path)
except Exception:
    print("別名ファイルを読めませんでした。")
    sys.exit(1)

if not data:
    print("保存済み別名はまだありません。")
    sys.exit(0)

def normalize(text):
    return " ".join(str(text).split())

def summary(record):
    title = normalize(record.get("title", ""))
    purpose = normalize(record.get("purpose", ""))
    remaining = record.get("remaining") or []
    load = record.get("session_load") or {}
    prefix = f"[{load.get('label')}]" if load.get("label") else ""
    if title and purpose and title != purpose:
        return f"{prefix} {title} / {purpose}".strip()[:72]
    if purpose and remaining:
        return f"{prefix} {purpose} / 残: {normalize(remaining[0])}".strip()[:72]
    if title and remaining:
        return f"{prefix} {title} / 残: {normalize(remaining[0])}".strip()[:72]
    if title:
        return f"{prefix} {title}".strip()[:72]
    if purpose:
        return f"{prefix} {purpose}".strip()[:72]
    return "復元メモ未登録"

print("alias                tool     updated_at                  summary")
print("-" * 120)
for alias, record in sorted(data.items()):
    merged = {}
    sid = record.get("session_id", "")
    if isinstance(index.get(sid), dict):
        merged.update(index[sid])
    merged.update(record)
    tool = record.get("tool", "-")
    updated_at = record.get("updated_at", "-")
    print(f"{alias:<20} {tool:<8} {updated_at:<26} {summary(merged)}")
PY
}

# ============================================================
# 自動引き継ぎコンテキスト生成
# ツールに「書き出して」と頼むのではなく、スクリプトが自動で収集する
# ============================================================
generate_auto_context() {
    cd "$PROJECT_DIR"

    local context=""
    local handoff_file
    local state_json
    local prev_tool
    local switched_at
    local current_work_id
    local current_work_title
    local current_handoff_path
    local current_batch_id
    local current_batch_title
    local current_batch_summary
    local current_batch_item_id
    local current_batch_item_title
    local compaction_required
    local compaction_summary
    local compaction_requested_at
    local last_session_load_summary
    compact_current_handoff_if_needed
    ensure_current_batch_item
    handoff_file="$(get_handoff_file)"
    state_json="$(work_state_status_json)"
    prev_tool="$(json_get "$state_json" "current_tool")"
    switched_at="$(json_get "$state_json" "switched_at")"
    current_work_id="$(json_get "$state_json" "current_work_id")"
    current_work_title="$(json_current_work_field "$state_json" "title")"
    current_handoff_path="$(json_current_work_field "$state_json" "handoff_path")"
    current_batch_id="$(json_current_work_field "$state_json" "current_batch_id")"
    current_batch_title="$(json_current_work_field "$state_json" "current_batch_title")"
    current_batch_summary="$(json_current_work_field "$state_json" "current_batch_summary")"
    current_batch_item_id="$(json_current_work_field "$state_json" "current_batch_item_id")"
    current_batch_item_title="$(json_current_work_field "$state_json" "current_batch_item_title")"
    compaction_required="$(json_current_work_field "$state_json" "compaction_required")"
    compaction_summary="$(json_current_work_field "$state_json" "compaction_summary")"
    compaction_requested_at="$(json_current_work_field "$state_json" "compaction_requested_at")"
    last_session_load_summary="$(json_current_work_field "$state_json" "last_session_load_summary")"

    # 1. git の変更状態（何が変わったか）
    local git_status
    git_status=$(git status --short 2>/dev/null || echo "git status unavailable")
    local git_diff_stat
    git_diff_stat=$(git diff --stat 2>/dev/null | tail -5 || echo "")

    # 2. 最近のコミット（何をやったか）
    local recent_commits
    recent_commits=$(git log --oneline -5 2>/dev/null || echo "")

    # 3. 引き継ぎファイルがあれば含める（前のツールが書き出したもの）
    local handoff_content=""
    if [ -f "$handoff_file" ]; then
        handoff_content=$(cat "$handoff_file")
    fi

    # コンテキストを構造化して組み立て
    cat <<CONTEXT
# 引き継ぎコンテキスト

## 前の担当ツール
${prev_tool}（切替時刻: ${switched_at:-不明}）

## 現在の仕事
ID: ${current_work_id:-未設定}
概要: ${current_work_title:-未設定}
正本 handoff: ${current_handoff_path:-未設定}
直近 session load: ${last_session_load_summary:-未設定}
current batch: ${current_batch_id:-未設定}

## 作業ディレクトリの状態
\`\`\`
${git_status}
\`\`\`

## 変更の概要
\`\`\`
${git_diff_stat}
\`\`\`

## 直近のコミット
\`\`\`
${recent_commits}
\`\`\`

CONTEXT

    # 前ツールが書き出した引き継ぎメモがあれば追加
    if [ -n "$handoff_content" ]; then
        printf '\n## 前の担当からの引き継ぎメモ\n%s\n\n' "$handoff_content"
    fi

    if [ -n "$current_batch_id" ]; then
        local batch_item_json
        batch_item_json="$(read_current_batch_item_json)"
        python3 - "$batch_item_json" "$current_batch_id" "$current_batch_title" "$current_batch_summary" "$current_batch_item_id" "$current_batch_item_title" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
item = payload.get("active_item") or {}
batch_id = sys.argv[2]
batch_title = sys.argv[3]
batch_summary = sys.argv[4]
item_id = sys.argv[5]
item_title = sys.argv[6]

print("")
print("## current batch")
print(f"batch_id: {batch_id}")
if batch_title:
    print(f"概要: {batch_title}")
if batch_summary:
    print(f"進捗: {batch_summary}")
if batch.get("schema_hint"):
    print(f"スキーマ: {batch.get('schema_hint','')}")
if batch.get("source"):
    print(f"ソース: {batch.get('source','')}")
if item_id:
    print("")
    print("### 実行中 item")
    print(f"item_id: {item_id}")
    print(f"タイトル: {item_title}")
if item.get("source_ref"):
    print(f"source_ref: {item.get('source_ref','')}")
if item.get("payload_preview"):
    print(f"payload: {item.get('payload_preview','')}")
print("")
PY
    fi

    if [ "$compaction_required" = "True" ] || [ "$compaction_required" = "true" ]; then
        cat <<COMPACTION

## handoff 圧縮要求
- 状態: pending
- 理由: ${compaction_summary:-前回セッションが長く、current work handoff を再圧縮する必要があります}
- 要求時刻: ${compaction_requested_at:-不明}
- 方針: 古い会話全文ではなく \`.ai_handoff.md\` と current work handoff を最新状態だけに再圧縮してから続ける

COMPACTION
    fi

    cat <<'INSTRUCTION'

## あなたへの指示
1. 上記のコンテキストを踏まえて作業を続けてください
2. 作業を終了する前に、必ず以下を .ai_handoff.md に書き出してください:
   - **目的**: 何のためにこの作業をしていたか
   - **完了したこと**: 具体的に何を終わらせたか
   - **未完了**: 残っているタスク
   - **判断とその理由**: なぜその選択をしたか（これが最重要）
   - **変更したファイル**: パスと変更内容の概要
   - **次の担当へ**: 次にやるべきこと、注意点
3. .ai_handoff.md は current work の mirror として同期される。案件全体の正本は System/data/ai_router/handoffs/<work_id>.md 側に保持される前提で書いてください
4. この引き継ぎメモなしにセッションを終了しないでください
5. `handoff 圧縮要求: pending` がある場合は、実装や調査を続ける前に `.ai_handoff.md` を最新状態だけに再圧縮してください
6. 再圧縮では `目的 / 確定事項 / 完了 / 未完了 / 判断と理由 / 参照先 / 変更したファイル / 次の担当へ` 以外を残さないでください
7. `current batch` がある場合は、その batch の active item を今回の処理単位として扱ってください
8. active item を完了したら `ai batch done <item_id> --summary "<結果要約>"` を実行し、失敗したら `ai batch fail <item_id> --error "<理由>"` を実行してください
9. active item が無い場合は `ai batch next` で次件を取得してから着手してください

INSTRUCTION
}

# ============================================================
# 自動判別
# ============================================================
classify_task() {
    local prompt="$1"
    # Claude Code はブラウザ操作や UI 操作が必要なときだけ使う
    if echo "$prompt" | grep -qiE 'ブラウザ|Looker|Addness.*画面|Addnessを開|Chrome|MCP|DOM|スクリーンショット|スクショ|画面確認|ページを開|クリック|ログイン|フォーム入力|browse|open page|screenshot'; then
        echo "claude"
    else
        # 原則は Codex。実装・修正・git 操作もまずこちら
        echo "codex"
    fi
}

parse_natural_session_request() {
    local prompt="$1"
    python3 - "$prompt" <<'PY'
import re
import sys

text = " ".join(sys.argv[1].split())
if not text:
    sys.exit(0)

restore_markers = ["復元", "再開", "続き", "戻りたい", "開きたい", "開いて"]
search_markers = ["探したい", "探して", "一覧", "候補", "見たい", "見せて", "調べたい"]
session_markers = ["セッション", "会話", "スレッド", "チャット"]
fork_markers = ["分岐", "別セッション", "fork"]
non_restore_markers = ["実装", "機能", "作って", "作成", "修正", "追加", "改善", "対応", "レビュー", "設計"]

has_session_marker = any(marker in text for marker in session_markers)
is_restore = any(marker in text for marker in restore_markers)
is_search = any(marker in text for marker in search_markers)

if not has_session_marker:
    sys.exit(0)
if any(marker in text for marker in non_restore_markers):
    sys.exit(0)

action = ""
if is_restore:
    action = "restore"
elif is_search:
    action = "sessions"
else:
    sys.exit(0)

mode = "fork" if any(marker in text for marker in fork_markers) else "resume"

quoted = re.findall(r'[「"\']([^「」"\']+)[」"\']', text)
query = quoted[0].strip() if quoted else text

patterns = [
    r'^(?:前回の?|前の|この|その)?',
    r'(?:について|関連)?の?(?:セッション|会話|スレッド|チャット)',
    r'(?:を|は|が|の)?(?:分岐して)?(?:復元|再開|検索|表示|一覧表示|一覧|確認|探索|調査)',
    r'(?:を|は|が|の)?(?:探したい|探して|見たい|見せて|開きたい|開いて|戻りたい|続きから(?:開きたい)?|続き(?:を)?(?:見たい|開きたい)?)',
    r'(?:ください|下さい|お願い(?:します)?|してほしい|したい|できますか|して)$',
]
for pattern in patterns:
    query = re.sub(pattern, " ", query)

query = re.sub(r'\b(?:session|sessions|restore|resume|search|fork)\b', ' ', query, flags=re.IGNORECASE)
query = re.sub(r'[?？!！、。]', ' ', query)
query = re.sub(r'\s+', ' ', query).strip()
query = query.strip(" のをはがにへと")

if not query:
    sys.exit(0)

print(f"{action}\t{mode}\t{query}")
PY
}

# ============================================================
# ツール起動（引き継ぎコンテキスト自動注入）
# ============================================================
launch_codex() {
    local prompt="${1:-}"
    local prepared_json="${2:-}"
    local context
    local final_prompt
    local rc
    if [ -z "$prepared_json" ]; then
        prepared_json="$(prepare_work_context "$prompt" "codex")"
    fi
    ensure_tool_available "codex" || return 1
    context=$(generate_auto_context)
    cd "$PROJECT_DIR"

    if [ -n "$prompt" ]; then
        final_prompt="${context}

---

ユーザーからの指示: ${prompt}"
    else
        final_prompt="$context"
    fi

    set +e
    "$CODEX_CMD" "$final_prompt"
    rc=$?
    set -e
    capture_latest_session_snapshot "codex"
    return "$rc"
}

launch_claude() {
    local prompt="${1:-}"
    local prepared_json="${2:-}"
    local context
    local final_prompt
    local rc
    if [ -z "$prepared_json" ]; then
        prepared_json="$(prepare_work_context "$prompt" "claude")"
    fi
    ensure_tool_available "claude" || return 1
    context=$(generate_auto_context)
    cd "$PROJECT_DIR"

    if [ -n "$prompt" ]; then
        final_prompt="${context}

---

ユーザーからの指示: ${prompt}"
    else
        final_prompt="$context"
    fi

    set +e
    "$CLAUDE_CMD" -p "$final_prompt"
    rc=$?
    set -e
    capture_latest_session_snapshot "claude"
    return "$rc"
}

# ============================================================
# メインロジック
# ============================================================
case "${1:-}" in
    switch)
        current=$(get_current_tool)
        handoff_file="$(get_handoff_file)"
        sync_root_handoff_to_work
        if [ "$current" = "codex" ]; then
            echo "🔄 Codex → Claude Code に切り替えます"
            echo ""
            # 自動でgit状態を収集するので、手動書き出し不要
            # ただし、前ツールが引き継ぎメモを書いてくれていれば最高
            if [ ! -f "$handoff_file" ]; then
                echo "⚠️  引き継ぎメモ（.ai_handoff.md）がありません。"
                echo "   Codex セッションで「引き継ぎメモを書いて」と言ってから終了するのがベストです。"
                echo "   ただし、git状態は自動で引き継がれます。"
                echo ""
            else
                echo "✅ 引き継ぎメモあり（$(wc -l < "$handoff_file" | tr -d ' ') 行）"
                echo ""
            fi
            echo "Enter で Claude Code を起動..."
            read -r
            launch_claude ""
        elif [ "$current" = "claude" ]; then
            echo "🔄 Claude Code → Codex に切り替えます"
            echo ""
            if [ ! -f "$handoff_file" ]; then
                echo "⚠️  引き継ぎメモ（.ai_handoff.md）がありません。"
                echo "   Claude Code セッションで「引き継ぎメモを書いて」と言ってから終了するのがベストです。"
                echo "   ただし、git状態は自動で引き継がれます。"
                echo ""
            else
                echo "✅ 引き継ぎメモあり（$(wc -l < "$handoff_file" | tr -d ' ') 行）"
                echo ""
            fi
            echo "Enter で Codex を起動..."
            read -r
            launch_codex ""
        else
            echo "現在アクティブなツールがありません。"
            echo "  ai codex  → Codex を起動"
            echo "  ai claude → Claude Code を起動"
            echo "  ai        → デフォルト（Codex）を起動"
        fi
        ;;

    status)
        current=$(get_current_tool)
        current_work_id="$(get_current_work_id)"
        state_json="$(work_state_status_json)"
        current_work_title="$(json_current_work_field "$state_json" "title")"
        current_handoff_path="$(json_current_work_field "$state_json" "handoff_path")"
        current_batch_id="$(json_current_work_field "$state_json" "current_batch_id")"
        current_batch_title="$(json_current_work_field "$state_json" "current_batch_title")"
        current_batch_summary="$(json_current_work_field "$state_json" "current_batch_summary")"
        current_batch_item_id="$(json_current_work_field "$state_json" "current_batch_item_id")"
        current_batch_item_title="$(json_current_work_field "$state_json" "current_batch_item_title")"
        handoff_file="$(get_handoff_file)"
        echo "=== AI ツール状態 ==="
        echo "アクティブ: $current"
        echo "現在の仕事: ${current_work_id:-なし}"
        echo "仕事の概要: ${current_work_title:-なし}"
        echo "仕事の正本 handoff: ${current_handoff_path:-なし}"
        if [ -n "$current_batch_id" ]; then
            echo "current batch: ${current_batch_id} / ${current_batch_title:-なし}"
            echo "batch 進捗: ${current_batch_summary:-なし}"
            if [ -n "$current_batch_item_id" ]; then
                echo "active item: ${current_batch_item_id} / ${current_batch_item_title:-なし}"
            fi
        fi
        compaction_required="$(json_current_work_field "$state_json" "compaction_required")"
        compaction_summary="$(json_current_work_field "$state_json" "compaction_summary")"
        if [ "$compaction_required" = "True" ] || [ "$compaction_required" = "true" ]; then
            echo "handoff 圧縮要求: pending"
            echo "圧縮理由: ${compaction_summary:-前回セッションが長いため}"
        fi
        if [ -f "$STATE_FILE" ]; then
            echo "最終切替: $(json_get "$state_json" "switched_at")"
        elif [ -f "$LEGACY_STATE_FILE" ]; then
            echo "最終切替: $(python3 -c "import json; print(json.load(open('$LEGACY_STATE_FILE')).get('switched_at','?'))" 2>/dev/null)"
        fi
        echo ""
        if [ -f "$handoff_file" ]; then
            echo "📋 引き継ぎメモ: あり ($(wc -l < "$handoff_file" | tr -d ' ') 行)"
            echo "━━━━━━━━━━━━━━━━━━"
            cat "$handoff_file"
            echo "━━━━━━━━━━━━━━━━━━"
        else
            echo "📋 引き継ぎメモ: なし"
        fi
        echo ""
        echo "=== Git 状態 ==="
        cd "$PROJECT_DIR"
        git status --short 2>/dev/null || echo "git unavailable"
        ;;

    doctor)
        doctor_runtime
        ;;

    works)
        shift
        list_work_records "${*:-}" "20"
        ;;

    work)
        shift
        activate_work_selection "${*:-}"
        ;;

    batches)
        shift
        list_batch_records "${*:-}" "20"
        ;;

    batch)
        shift || true
        subcommand="${1:-}"
        if [ $# -gt 0 ]; then
            shift
        fi
        case "$subcommand" in
            ""|help|--help|-h)
                cat <<'BATCH_HELP'
ai batch - batch queue 管理

使い方:
  ai batches [検索語]                         batch 一覧を表示
  ai batch create <title> [--tool codex|claude] [--type 種別] [--source 出所] [--schema 要件]
  ai batch import <batch> <jsonl_path>       JSONL をまとめて投入
  ai batch sync <batch>                      source から新規 item を自動投入
  ai batch show [batch]                      batch の詳細と active item を表示
  ai batch skills [検索語]                   自動生成された skill 候補を一覧表示
  ai batch start <batch> [--launch]          current work に接続し、必要なら次件を取得
  ai batch next [batch]                      active item を表示。無ければ次件を取得
  ai batch done [item_id] --summary <要約>   active item を完了扱いにする
  ai batch fail [item_id] --error <理由>     active item を失敗扱いにする
  ai batch release [item_id]                 active item を pending に戻す
BATCH_HELP
                ;;

            create)
                if [ $# -lt 1 ]; then
                    echo "使い方: ai batch create <title> [--tool codex|claude] [--type 種別] [--source 出所] [--schema 要件]"
                    exit 1
                fi
                batch_title="$1"
                shift
                batch_tool="codex"
                batch_type=""
                batch_source=""
                batch_schema=""
                while [ $# -gt 0 ]; do
                    case "${1:-}" in
                        --tool)
                            batch_tool="${2:-codex}"
                            shift 2
                            ;;
                        --type)
                            batch_type="${2:-}"
                            shift 2
                            ;;
                        --source)
                            batch_source="${2:-}"
                            shift 2
                            ;;
                        --schema)
                            batch_schema="${2:-}"
                            shift 2
                            ;;
                        *)
                            echo "不明な引数です: $1"
                            exit 1
                            ;;
                    esac
                done
                batch_payload="$(create_batch_record "$batch_title" "$batch_tool" "$batch_type" "$batch_source" "$batch_schema")"
                python3 - "$batch_payload" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
print("batch を作成しました。")
print(f"batch_id: {batch.get('batch_id','')}")
print(f"概要: {batch.get('title','')}")
print(f"担当ツール: {batch.get('preferred_tool','')}")
print(f"次: ai batch start {batch.get('batch_id','')} --launch")
PY
                ;;

            import)
                if [ $# -lt 2 ]; then
                    echo "使い方: ai batch import <batch_id|キーワード> <jsonl_path>"
                    exit 1
                fi
                batch_id="$(resolve_batch_id "$1")" || exit 1
                import_path="$2"
                import_payload="$(import_batch_jsonl "$batch_id" "$import_path")"
                python3 - "$import_payload" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
print("batch に投入しました。")
print(f"batch_id: {batch.get('batch_id','')}")
print(f"投入件数: {payload.get('imported_count', 0)}")
print(f"重複skip: {payload.get('skipped_count', 0)}")
print(f"進捗: {batch.get('summary','')}")
PY
                ;;

            sync)
                if [ $# -lt 1 ]; then
                    echo "使い方: ai batch sync <batch_id|キーワード>"
                    exit 1
                fi
                batch_id="$(resolve_batch_id "$1")" || exit 1
                sync_payload="$(sync_batch_source_json "$batch_id")"
                python3 - "$sync_payload" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
batch = payload.get("batch") or {}
print("source から同期しました。")
print(f"batch_id: {batch.get('batch_id','')}")
print(f"投入件数: {payload.get('imported_count', 0)}")
print(f"重複skip: {payload.get('skipped_count', 0)}")
print(f"source sync: {batch.get('source_last_sync_summary','')}")
PY
                ;;

            show)
                show_batch_record "${*:-}"
                ;;

            skills)
                list_skill_candidate_records "${*:-}" "20"
                ;;

            start)
                if [ $# -lt 1 ]; then
                    echo "使い方: ai batch start <batch_id|キーワード> [--launch]"
                    exit 1
                fi
                launch_flag="0"
                batch_query="$1"
                shift
                while [ $# -gt 0 ]; do
                    case "${1:-}" in
                        --launch)
                            launch_flag="1"
                            shift
                            ;;
                        *)
                            echo "不明な引数です: $1"
                            exit 1
                            ;;
                    esac
                done
                start_batch_work "$batch_query" "$launch_flag"
                ;;

            next)
                claim_next_batch_item "${*:-}"
                ;;

            done)
                item_id="${1:-}"
                if [ $# -gt 0 ] && [[ "$item_id" != --* ]]; then
                    shift
                else
                    item_id=""
                fi
                complete_current_batch_item "$item_id" "$@"
                ;;

            fail)
                item_id="${1:-}"
                if [ $# -gt 0 ] && [[ "$item_id" != --* ]]; then
                    shift
                else
                    item_id=""
                fi
                fail_current_batch_item "$item_id" "$@"
                ;;

            release)
                release_current_batch_item "${1:-}"
                ;;

            *)
                echo "不明な batch サブコマンドです: $subcommand"
                exit 1
                ;;
        esac
        ;;

    sessions)
        shift
        list_sessions "${*:-}" "20"
        ;;

    session)
        shift || true
        subcommand="${1:-}"
        if [ $# -gt 0 ]; then
            shift
        fi
        case "$subcommand" in
            ""|help|--help|-h)
                cat <<'SESSION_HELP'
ai session - session snapshot の保存/検証

使い方:
  ai session snapshot [codex|claude] [session_id] [preview]
  ai session verify [codex|claude] [session_id]
SESSION_HELP
                ;;

            snapshot)
                session_tool="${1:-$(get_current_tool)}"
                if [ $# -gt 0 ]; then
                    shift || true
                fi
                session_id="${1:-}"
                if [ $# -gt 0 ]; then
                    shift || true
                fi
                session_preview="${*:-}"
                snapshot_latest_session "$session_tool" "$session_id" "$session_preview"
                ;;

            verify)
                session_tool="${1:-$(get_current_tool)}"
                if [ $# -gt 0 ]; then
                    shift || true
                fi
                session_id="${1:-}"
                if [ -z "$session_tool" ] || [ "$session_tool" = "none" ]; then
                    echo "使い方: ai session verify [codex|claude] [session_id]"
                    exit 1
                fi
                verify_payload="$(verify_session_snapshot_json "$session_tool" "$session_id")"
                python3 - "$verify_payload" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1] or "{}")
print(f"tool: {payload.get('tool','')}")
print(f"session_id: {payload.get('session_id','') or '未検出'}")
print(f"session record: {'OK' if payload.get('session_found') else 'NG'}")
print(f"snapshot record: {'OK' if payload.get('snapshot_found') else 'NG'}")
for key, label in (
    ("snapshot_content", "handoff 要約"),
    ("session_metrics", "metrics"),
    ("session_load", "load"),
    ("work_link", "work 紐づけ"),
):
    print(f"{label}: {'OK' if payload.get('checks', {}).get(key) else 'NG'}")
if payload.get("work_id"):
    print(f"work_id: {payload.get('work_id','')}")
if payload.get("snapshot_title"):
    print(f"title: {payload.get('snapshot_title','')}")
PY
                ;;

            *)
                echo "不明な session サブコマンドです: $subcommand"
                exit 1
                ;;
        esac
        ;;

    restore)
        shift
        restore_session "$@"
        ;;

    pin)
        shift
        pin_session_alias "$@"
        ;;

    pins)
        list_session_aliases
        ;;

    codex)
        shift
        launch_codex "${*:-}"
        ;;

    claude)
        shift
        launch_claude "${*:-}"
        ;;

    help|--help|-h)
        cat <<'HELP'
ai - Claude Code / Codex CLI シームレス切り替え

使い方:
  ai "タスク内容"         自動判別で適切なツールを起動
  ai codex "タスク"       Codex CLI を起動
  ai claude "タスク"      Claude Code を起動
  ai switch              ツール間切り替え（自動引き継ぎ）
  ai status              現在の状態 + 引き継ぎメモを表示
  ai doctor              パス解決と復元素材の存在を確認
  ai works [検索語]       current work を一覧/検索
  ai work [ID|語]         current work を表示/切り替え
  ai batches [検索語]     batch queue を一覧/検索
  ai batch ...            batch queue を作成/投入/進行
  ai sessions [検索語]    保存済みセッションを一覧/検索（load付き）
  ai session ...          session snapshot の保存/検証
  ai restore <ID|語>      セッションを再開。重い場合は自動で fork
  ai restore --fork <...> セッションを分岐復元
  ai restore --force-resume <...> auto-fork を抑止してそのまま再開
  ai pin <別名> <ID|語>   セッションに人間向けの別名を付ける
  ai pins                保存済み別名を一覧表示
  ai "導線のセッションを復元したい"  日本語の自然文で復元
  ai "導線のセッションを探したい"    日本語の自然文で候補表示

自動判別ルール:
  原則（→Codex）: 実装/修正/git操作/分析/企画を含む通常作業全般
  例外（→Claude）: ブラウザ操作/Looker/Addness画面/Chrome MCP/画面確認
  デフォルト: Codex

引き継ぎの仕組み:
  1. git状態（status/diff/最近のcommit）は自動で引き継がれる
  2. current work の正本は System/data/ai_router/ に保持される
  3. .ai_handoff.md は current work の mirror として同期される
  4. ai works / ai work で current work の一覧と切り替えができる
  5. セッション終了時に、目的/完了/未完了を session_restore_index.json に自動保存する
  6. ai sessions / ai pins で目的や残タスクに加えて session load も見える
  7. ai restore は保存済み要約を表示し、長セッションなら自動で fork して復元メモを注入する
 8. 生 resume が必要な時だけ ai restore --force-resume を使う
 9. よく使うセッションは ai pin で別名保存しておくと、ai restore <別名> ですぐ戻せる
10. 同型タスクは ai batch create / import / start で queue 化し、current work に active item を注入できる

移行時の補足:
  - PROJECT_DIR は ai スクリプトの位置から自動解決
  - Codex / Claude は PATH を優先し、無ければ ~/.npm-global/bin/codex と ~/.local/bin/claude を探す
  - 必要なら AI_PROJECT_DIR / AI_CODEX_CMD / AI_CLAUDE_CMD で上書きできる
  - 移行後は ai doctor -> ai status -> ai restore <別名> の順で確認する
HELP
        ;;

    "")
        # 引数なし → デフォルトでCodexを起動
        launch_codex ""
        ;;

    *)
        natural_session_request="$(parse_natural_session_request "$*")"
        if [ -n "${natural_session_request:-}" ]; then
            action="$(printf '%s' "$natural_session_request" | cut -f1)"
            mode="$(printf '%s' "$natural_session_request" | cut -f2)"
            query="$(printf '%s' "$natural_session_request" | cut -f3-)"
            if [ "$action" = "restore" ]; then
                if [ "$mode" = "fork" ]; then
                    restore_session --fork "$query"
                else
                    restore_session "$query"
                fi
            else
                list_sessions "$query" "20"
            fi
        else
            prepared_json="$(prepare_work_context "$*" "auto")"
            tool="$(json_get "$prepared_json" "selected_tool")"
            if [ "$tool" = "codex" ]; then
                echo "🧠 → Codex (原則: 通常作業)"
                launch_codex "$*" "$prepared_json"
            else
                echo "🌐 → Claude Code (例外: ブラウザ操作)"
                launch_claude "$*" "$prepared_json"
            fi
        fi
        ;;
esac
